# Authentication and Database (provided by AI Studio internally)
# When deploying to Render, you must set these if you use your own Firebase.
# Otherwise, export the app configuration.

# Gemini API Key (Required for AI Grooming)
# Use GEMINI_API_KEY for AI Studio or VITE_GEMINI_API_KEY for Netlify/Local
GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Config (Optional if using project defaults)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_PROJECT_ID=
